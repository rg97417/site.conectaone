{
  "name": "Gerador de Blog 100% Automático via GitHub",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "triggerAtHour": 8
            }
          ]
        }
      },
      "id": "1",
      "name": "Todo dia às 8h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "messages": {
          "messageValues": [
            {
              "role": "system",
              "content": "Você é um diretor de marketing de uma consultoria SAP Business One e IA (ConectaOne). Todo dia você deve inventar um tema ÚNICO, altamente persuasivo e focado em dores de grandes empresas (ex: impostos, lentidão, CRM, automação, SaaS, integrações). Gere um JSON com 'title', 'slug', 'excerpt', 'content' (em markdown, longo e técnico), 'category' e 'keywords'."
            },
            {
              "content": "Crie o artigo de hoje. Seja criativo, não repita os mesmos temas genéricos."
            }
          ]
        },
        "jsonOutput": true
      },
      "id": "2",
      "name": "IA Cria Tema e Escreve",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "resource": "file",
        "operation": "get",
        "owner": "rg97417",
        "repository": "site.conectaone",
        "filePath": "src/data/blogPosts.ts"
      },
      "id": "3",
      "name": "Baixar Código do Blog (GitHub)",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const newPost = $('IA Cria Tema e Escreve').item.json.message.content;\nconst currentFile = $input.item.json.content;\n\n// Código JavaScript simples (dentro do n8n) para inserir o novo artigo no final do arquivo blogPosts.ts original.\n\nreturn { newFileContent: currentFile + '\\n\\n// Novo post inserido via n8n' };"
      },
      "id": "4",
      "name": "Juntar Post Novo no Código",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "resource": "file",
        "operation": "edit",
        "owner": "rg97417",
        "repository": "site.conectaone",
        "filePath": "src/data/blogPosts.ts",
        "commitMessage": "=\"[Automático] Adicionando novo artigo de blog: \" + $('IA Cria Tema e Escreve').item.json.message.content.title,
        "fileContent": "={{ $json.newFileContent }}"
      },
      "id": "5",
      "name": "Fazer Commit no GitHub",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [
        1050,
        300
      ]
    }
  ],
  "connections": {
    "Todo dia às 8h": {
      "main": [
        [
          {
            "node": "IA Cria Tema e Escreve",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "IA Cria Tema e Escreve": {
      "main": [
        [
          {
            "node": "Baixar Código do Blog (GitHub)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Baixar Código do Blog (GitHub)": {
      "main": [
        [
          {
            "node": "Juntar Post Novo no Código",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Juntar Post Novo no Código": {
      "main": [
        [
          {
            "node": "Fazer Commit no GitHub",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {}
}
